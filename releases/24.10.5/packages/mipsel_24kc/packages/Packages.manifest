Package: hexedit
Version: 1.6-r1
Depends: libc, libncurses6
Source: feeds/packages/utils/hexedit
SourceName: hexedit
License: GPL-2.0-or-later
LicenseFiles: COPYING
Section: utils
SourceDateEpoch: 1761595978
