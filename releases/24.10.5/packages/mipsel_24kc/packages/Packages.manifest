Package: gensio-bin
Version: 2.8.4-r1
Depends: libc, libgensio0
Source: feeds/packages/net/gensio
SourceName: gensio
License: GPL-2.0-or-later
LicenseFiles: COPYING
Section: net
SourceDateEpoch: 1761595978
